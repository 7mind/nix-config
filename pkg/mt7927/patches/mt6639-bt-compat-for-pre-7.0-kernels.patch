Bluetooth: btusb/btmtk: compat fixes for pre-7.0 host kernels

This DKMS package extracts btusb.c and btmtk.c from the kernel 7.1.1
tarball but compiles them against the host kernel, which is commonly
6.17 through 7.0 (Fedora 43, Ubuntu 24.04, Bazzite, Proxmox, etc.).

Two pre-7.0 build issues arise:

1. kmalloc_obj() / kzalloc_obj() (introduced in 7.0, commit 2932ba8d9c99
   "slab: Introduce kmalloc_obj() and family"). On pre-7.0 hosts the
   build fails with "call to undeclared function". Replace the three
   call sites with their kmalloc/kzalloc equivalents; kmalloc_obj(*x)
   expands to kmalloc(sizeof(*x), GFP_KERNEL) upstream, so behavior is
   identical, and the plain form is valid on every kernel.

2. hci_discovery_active() was only EXPORT_SYMBOL'd in 7.0 (commit
   97eb023cd161 "Bluetooth: hci_core: Export hci_discovery_active").
   Built against a <7.0 host the module fails to link. Version-guard the
   call so pre-7.0 hosts drop it while 7.0+ hosts keep the discovery-
   active auto-suspend guard intact.

--- a/btmtk.c
+++ b/btmtk.c
@@ -579,7 +579,7 @@
 	if (!urb)
 		return -ENOMEM;
 
-	dr = kmalloc_obj(*dr);
+	dr = kmalloc(sizeof(*dr), GFP_KERNEL);
 	if (!dr) {
 		usb_free_urb(urb);
 		return -ENOMEM;
--- a/btusb.c
+++ b/btusb.c
@@ -7,6 +7,7 @@
  */
 
 #include <linux/dmi.h>
+#include <linux/version.h>
 #include <linux/module.h>
 #include <linux/usb.h>
 #include <linux/usb/quirks.h>
@@ -2099,7 +2100,7 @@
 	if (!urb)
 		return ERR_PTR(-ENOMEM);
 
-	dr = kmalloc_obj(*dr);
+	dr = kmalloc(sizeof(*dr), GFP_KERNEL);
 	if (!dr) {
 		usb_free_urb(urb);
 		return ERR_PTR(-ENOMEM);
@@ -4079,7 +4080,7 @@
 			return -ENODEV;
 	}
 
-	data = kzalloc_obj(*data);
+	data = kzalloc(sizeof(*data), GFP_KERNEL);
 	if (!data)
 		return -ENOMEM;
 
@@ -4481,8 +4482,12 @@
 	/* Don't auto-suspend if there are connections or discovery in
 	 * progress; external suspend calls shall never fail.
 	 */
+#if LINUX_VERSION_CODE < KERNEL_VERSION(7, 0, 0)
+	if (PMSG_IS_AUTO(message) && hci_conn_count(data->hdev))
+#else
 	if (PMSG_IS_AUTO(message) &&
 	    (hci_conn_count(data->hdev) || hci_discovery_active(data->hdev)))
+#endif
 		return -EBUSY;
 
 	if (data->suspend_count++)
