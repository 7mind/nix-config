#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")" && pwd)"
SECRETS_DIR="$REPO_ROOT/private/secrets/generic"
CONTAINERS_DIR="$REPO_ROOT/private/hosts/vm/containers"

# Profile definitions
declare -A PROFILE_PEERS_FILE
declare -A PROFILE_SECRETS_PREFIX
declare -A PROFILE_SUBNET

PROFILE_PEERS_FILE[pg]="$CONTAINERS_DIR/pg-awg-peers.json"
PROFILE_PEERS_FILE[7mind]="$CONTAINERS_DIR/7mind-awg-peers.json"

PROFILE_SECRETS_PREFIX[pg]="awg"
PROFILE_SECRETS_PREFIX[7mind]="7mind-awg"

PROFILE_SUBNET[pg]="10.100.0"
PROFILE_SUBNET[7mind]="10.101.0"

KNOWN_PROFILES="${!PROFILE_PEERS_FILE[*]}"

# Ensure required tools are available
missing=()
for cmd in wg age jq; do
  command -v "$cmd" &>/dev/null || missing+=("$cmd")
done
if [[ ${#missing[@]} -gt 0 ]]; then
  echo "Missing tools: ${missing[*]}" >&2
  echo "Run with: nix shell nixpkgs#wireguard-tools nixpkgs#age nixpkgs#jq --command $0 \"\$@\"" >&2
  exit 1
fi

# Read age pubkey from setup-env
declare -A group_pubkeys
source "$REPO_ROOT/private/setup-env"
AGE_PUBKEY="${group_pubkeys[infra]}"

usage() {
  echo "Usage: $0 <$KNOWN_PROFILES> <client-name> [--ip <ip>]" >&2
  echo "       $0 <$KNOWN_PROFILES> --init" >&2
  echo "" >&2
  echo "Adds a new AmneziaWG client to the specified profile." >&2
  echo "" >&2
  echo "Commands:" >&2
  echo "  <name>     Add a new client (generates keypair + PSK, encrypts, updates JSON)" >&2
  echo "  --init     Generate server key for a new profile" >&2
  echo "" >&2
  echo "Options:" >&2
  echo "  --ip <ip>  Override auto-allocated IP" >&2
  exit 1
}

PROFILE=""
CLIENT_NAME=""
CLIENT_IP=""
INIT_MODE=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    --ip) CLIENT_IP="$2"; shift 2 ;;
    --init) INIT_MODE=true; shift ;;
    --help|-h) usage ;;
    -*) echo "Unknown option: $1" >&2; usage ;;
    *)
      if [[ -z "$PROFILE" ]]; then
        PROFILE="$1"
      elif [[ -z "$CLIENT_NAME" ]]; then
        CLIENT_NAME="$1"
      else
        echo "Unexpected argument: $1" >&2
        usage
      fi
      shift
      ;;
  esac
done

[[ -n "$PROFILE" ]] || usage

# Validate profile
if [[ -z "${PROFILE_PEERS_FILE[$PROFILE]+x}" ]]; then
  echo "ERROR: Unknown profile '$PROFILE'. Must be one of: $KNOWN_PROFILES" >&2
  exit 1
fi

PEERS_FILE="${PROFILE_PEERS_FILE[$PROFILE]}"
SECRETS_PREFIX="${PROFILE_SECRETS_PREFIX[$PROFILE]}"
SUBNET="${PROFILE_SUBNET[$PROFILE]}"

# --init: generate server key for a new profile
if [[ "$INIT_MODE" == true ]]; then
  SERVER_KEY_FILE="$SECRETS_DIR/${SECRETS_PREFIX}-server-key.age"
  if [[ -f "$SERVER_KEY_FILE" ]]; then
    echo "ERROR: Server key already exists: $SERVER_KEY_FILE" >&2
    exit 1
  fi

  SERVER_PRIVKEY="$(wg genkey)"
  SERVER_PUBKEY="$(echo "$SERVER_PRIVKEY" | wg pubkey)"
  echo "$SERVER_PRIVKEY" | age -e -r "$AGE_PUBKEY" -o "$SERVER_KEY_FILE"
  echo "Saved: $SERVER_KEY_FILE"

  jq --arg pk "$SERVER_PUBKEY" '.serverPublicKey = $pk | .ageEnabled = true' "$PEERS_FILE" > "${PEERS_FILE}.tmp"
  mv "${PEERS_FILE}.tmp" "$PEERS_FILE"
  echo "Server public key: $SERVER_PUBKEY"
  echo "Updated: $PEERS_FILE"

  echo ""
  echo "Next steps:"
  echo "  1. Commit the changes"
  echo "  2. Run: ./setup -k vm"
  echo "  3. Deploy to VM host"
  exit 0
fi

[[ -n "$CLIENT_NAME" ]] || usage

# Validate client name
if ! [[ "$CLIENT_NAME" =~ ^[a-z0-9][a-z0-9-]*$ ]]; then
  echo "ERROR: Client name must match [a-z0-9][a-z0-9-]*" >&2
  exit 1
fi

# Check for duplicate name
if jq -e --arg name "$CLIENT_NAME" '.peers[] | select(.name == $name)' "$PEERS_FILE" >/dev/null 2>&1; then
  echo "ERROR: Client '$CLIENT_NAME' already exists in profile '$PROFILE'" >&2
  exit 1
fi

# Auto-allocate IP if not specified
if [[ -z "$CLIENT_IP" ]]; then
  USED_IPS=$(jq -r '.peers[].ip' "$PEERS_FILE")
  for i in $(seq 2 254); do
    CANDIDATE="${SUBNET}.$i"
    if ! echo "$USED_IPS" | grep -qxF "$CANDIDATE"; then
      CLIENT_IP="$CANDIDATE"
      break
    fi
  done
  if [[ -z "$CLIENT_IP" ]]; then
    echo "ERROR: No available IPs in ${SUBNET}.0/24" >&2
    exit 1
  fi
fi

echo "[$PROFILE] Adding client: $CLIENT_NAME ($CLIENT_IP/32)"
echo ""

# Generate keys
PRIVKEY="$(wg genkey)"
PUBKEY="$(echo "$PRIVKEY" | wg pubkey)"
PSK="$(wg genpsk)"

# Encrypt and save
echo "$PRIVKEY" | age -e -r "$AGE_PUBKEY" -o "$SECRETS_DIR/${SECRETS_PREFIX}-key-${CLIENT_NAME}.age"
echo "$PSK" | age -e -r "$AGE_PUBKEY" -o "$SECRETS_DIR/${SECRETS_PREFIX}-psk-${CLIENT_NAME}.age"
echo "Saved: ${SECRETS_PREFIX}-key-${CLIENT_NAME}.age"
echo "Saved: ${SECRETS_PREFIX}-psk-${CLIENT_NAME}.age"

# Add peer to JSON
jq --arg name "$CLIENT_NAME" \
   --arg pubkey "$PUBKEY" \
   --arg ip "$CLIENT_IP" \
   '.peers += [{"name": $name, "publicKey": $pubkey, "ip": $ip}]' \
   "$PEERS_FILE" > "${PEERS_FILE}.tmp"
mv "${PEERS_FILE}.tmp" "$PEERS_FILE"
echo "Updated: $PEERS_FILE"

# Read params from JSON for client config
AWG_ENDPOINT="$(jq -r '.awgEndpoint' "$PEERS_FILE")"
DNS_IP="${SUBNET}.1"
SERVER_PUBKEY="$(jq -r '.serverPublicKey // empty' "$PEERS_FILE")"

if [[ -n "$SERVER_PUBKEY" && "$SERVER_PUBKEY" != "null" ]]; then
  # Build AWG params block from JSON
  AWG_PARAMS="$(jq -r '.awgParams | to_entries | map("\(.key) = \(.value)") | join("\n")' "$PEERS_FILE")"

  CONFIG="[Interface]
PrivateKey = $PRIVKEY
Address = $CLIENT_IP/32
DNS = $DNS_IP
$AWG_PARAMS

[Peer]
PublicKey = $SERVER_PUBKEY
PresharedKey = $PSK
Endpoint = $AWG_ENDPOINT
AllowedIPs = 0.0.0.0/0
PersistentKeepalive = 25"

  echo ""
  echo "==========================================="
  echo "  Client config: $CLIENT_NAME ($CLIENT_IP/32)"
  echo "==========================================="
  echo "$CONFIG"
  echo ""
  if command -v qrencode &>/dev/null; then
    echo "$CONFIG" | qrencode -t UTF8
  else
    echo "(install qrencode for QR code output)"
  fi
else
  echo ""
  echo "Server public key not yet known. Initialize with:"
  echo "  $0 $PROFILE --init"
fi

echo ""
echo "Next steps:"
echo "  1. Commit the changes"
echo "  2. Run: ./setup -k vm   (rekey secrets for VM host)"
echo "  3. Deploy to VM host"
